{
  "name": "ai-cli-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "bin": {
    "ai-cli-manager": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "start": "node dist/cli.js",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "cross-spawn": "^7.0.6"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
